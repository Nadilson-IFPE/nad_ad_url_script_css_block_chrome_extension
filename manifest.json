{
  "manifest_version": 3,
  "name": "Bloqueador de Sites de Anúncios",
  "version": "1.0",
  "description": "Uma extensão que bloqueia sites de anúncios específicos.",
  "author": "Nadilson J. R. Teixeira",
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules/rules_1.json"
      }
    ]
  },
  "permissions": [
    "declarativeNetRequest", 
	"declarativeNetRequestFeedback", 
	"tabs",
	"webRequest",
	"webRequestBlocking",
	"declarativeNetRequestWithHostAccess",
	"scripting",
	"storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "incognito": "spanning",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon48.png"
  },
  "background": {
    "service_worker": "scripts/service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["rules/rules_1.json", "popup/popup.js", "messages/message.html"],
      "matches": ["<all_urls>"]
    }
  ]
}